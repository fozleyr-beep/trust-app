{
  "name": "trust-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "doctor": "tsx scripts/doctor.ts",
    "doctor:json": "tsx scripts/doctor.ts --json",
    "smoke:prod": "tsx scripts/smoke-production.ts",
    "mobile:start": "npm --prefix mobile run start",
    "mobile:android": "npm --prefix mobile run android",
    "mobile:check": "tsx scripts/check-mobile-readiness.ts",
    "android:release-check": "tsx scripts/check-android-release-readiness.ts",
    "mobile:typecheck": "npm --prefix mobile run typecheck",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "tsx scripts/check-schema-drift.ts",
    "check:bundle": "tsx scripts/check-bundle-budget.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clerk/nextjs": "^6.10.0",
    "@neondatabase/serverless": "^0.10.4",
    "@playwright/test": "^1.59.1",
    "drizzle-orm": "^0.36.4",
    "next": "15.5.15",
    "next-intl": "^4.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svix": "^1.92.2",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.0",
    "@types/react": "^19.0.5",
    "@types/react-dom": "^19.0.3",
    "@vitest/ui": "^4.1.6",
    "drizzle-kit": "^0.30.1",
    "eslint": "^10.4.0",
    "eslint-config-next": "15.5.15",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
