# ─── Clerk ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret — set in Clerk dashboard → Webhooks → endpoint
# Format: whsec_...
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# ─── Twilio Verify (phone proof) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ─── Neon Postgres (Drizzle) ──────────────────────────────────────────
DATABASE_URL=

# ─── Anthropic (Claude Sonnet 4.5) ────────────────────────────────────
# Production can use Vercel AI Gateway via project OIDC instead of a raw
# Anthropic key. For local assistant testing, set one of these.
AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=

# ─── Stripe (self-serve billing launch gate) ──────────────────────────
# Optional until payments go live. When both are set, /app/billing can open
# hosted Stripe Checkout without a sales call or manual invoice.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ─── Private media (photo gate + voice purge launch gate) ─────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sakinah-photos
R2_BUCKET_VOICE=sakinah-voice
PHOTO_ACCESS_TOKEN_SECRET=

# ─── Observability (privacy-conserving) ───────────────────────────────
POSTHOG_KEY=
POSTHOG_HOST=
SENTRY_DSN=
CRON_SECRET=
